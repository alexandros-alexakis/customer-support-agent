# Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# =============================================================
# ANTHROPIC API KEY
# Required for: LLM mode (real Claude responses), multilingual
# Not required for: triage engine, tests, mock mode
# Get yours at: https://console.anthropic.com
# Note: API usage costs money. Free tier has limits.
# =============================================================
ANTHROPIC_API_KEY=

# =============================================================
# RUN MODE
# mock = no API calls, deterministic output, free, good for testing
# llm  = real Claude API calls, costs credits
# Default: auto-detected (mock if no API key, llm if key is set)
# =============================================================
# AGENT_MODE=mock

# =============================================================
# ZENDESK INTEGRATION
# Only needed if running integrations/zendesk_webhook.py
# Leave blank if not using Zendesk
# =============================================================
# Subdomain: if your URL is yourcompany.zendesk.com, enter: yourcompany
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# =============================================================
# HELPSHIFT INTEGRATION
# Only needed if running integrations/helpshift_webhook.py
# Leave blank if not using Helpshift
# =============================================================
# Domain: the subdomain part of your Helpshift URL
HELPSHIFT_API_KEY=
HELPSHIFT_DOMAIN=
HELPSHIFT_WEBHOOK_SECRET=

# =============================================================
# PLAYER ACCOUNT BACKEND
# mock = deterministic fake data (default, no setup needed)
# real = calls internal account API (not yet implemented)
# =============================================================
# PLAYER_ACCOUNT_BACKEND=mock

# =============================================================
# SERVER
# =============================================================
PORT=8000
