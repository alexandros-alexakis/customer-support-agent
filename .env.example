# Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Anthropic API key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Zendesk credentials
# Subdomain: if your Zendesk URL is yourcompany.zendesk.com, enter: yourcompany
ZENDESK_SUBDOMAIN=yourcompany

# Admin email address registered in Zendesk
ZENDESK_EMAIL=support@yourcompany.com

# Zendesk API token
# Admin Center > Apps and Integrations > APIs > Zendesk API > Add API token
ZENDESK_API_TOKEN=your_zendesk_api_token_here

# Webhook signing secret
# Generated in Zendesk when you create the webhook
# Generate a random one with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your_webhook_secret_here

# Server port (optional, defaults to 8000)
PORT=8000
